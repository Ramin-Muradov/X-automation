# ================================
# X (Twitter) API Açarları
# developer.twitter.com saytından əldə edin
# ================================
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_key_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
X_BEARER_TOKEN=your_bearer_token_here

# ================================
# Grok API (xAI) — Trend Analizi
# console.x.ai → API Keys
# ================================
GROK_API_KEY=your_grok_api_key_here

# ================================
# DeepSeek API — Məzmun Yazımı
# platform.deepseek.com → API Keys
# ================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ================================
# Post Parametrləri
# ================================
# Postun göndəriləcəyi vaxt (24 saat, HH:MM)
POST_TIME=09:00

# Video Repost Parametrləri
VIDEO_REPOST_TIME=18:00
VIDEO_REPOST_ENABLED=true
VIDEO_REPOST_MIN_FOLLOWERS=50000
VIDEO_REPOST_WINDOW_HOURS=24

# Zaman zolağı (pytz formatı)
TIMEZONE=Asia/Baku

# Post dili
POST_LANGUAGE=English

# Biznes sahəsi (Grok trend axtarışı üçün)
BUSINESS_NICHE=Business, Startups, Finance

# ================================
# Media Parametrləri
# ================================
MEDIA_FOLDER=data/media

# ================================
# Sistem Parametrləri
# ================================
DRY_RUN=false
LOG_LEVEL=INFO
